sophos:
  host: ""                      # Sophos XGS IP or hostname — configure in the web UI
  ssh_port: 22
  api_port: 4444
  username: admin
  password: ""                  # Set via Settings in the dashboard
  # api_password: ""            # Optional: separate WebAdmin API password. Defaults to 'password' above.
  verify_ssl: false
  poll_interval_leases: 60      # seconds between SSH lease refresh
  poll_interval_config: 300     # seconds between XML API config refresh
  # ssh_host_key: ""            # Auto-populated on first SSH connect (TOFU). Clear to re-trust a changed key.

unifi:
  host: ""                      # UniFi controller IP or hostname — configure in the web UI
  username: ""
  password: ""                  # Set via Settings in the dashboard
  site: default
  verify_ssl: false
  poll_interval: 30             # seconds between UniFi client refresh

app:
  port: 8080
  log_level: info               # debug | info | warning | error
                                # Note: log level in gwless.service is separate; change ExecStart there too.
  oui_update_on_start: true     # download OUI vendor database if not present
  # secret: ""                  # Optional: protects Settings/refresh endpoints. Set here, enter in the UI Secret field.

syslog:
  enabled: false                # Enable embedded UDP syslog receiver
  port: 514                     # UDP port (514 requires root / privileged container)
  bind_host: "0.0.0.0"         # Listen address (0.0.0.0 = all interfaces)
  # Configure Sophos: Logging & Monitoring → Log Settings → add this container's IP,
  # Protocol UDP, Port 514, Format Default. Enable "Event" logs with DHCP component.
  # When enabled, syslog is preferred over SSH for live DHCP lease data.
